# ─── Copie este arquivo para .env e preencha os valores ───────────────────
# O .env NUNCA deve ser commitado no Git (já está no .gitignore)

# Flask
SECRET_KEY=coloque-uma-chave-secreta-aleatoria-aqui

# Supabase PostgreSQL — Transaction Pooler (copie do dashboard Supabase)
# Settings → Database → Connection String → Transaction pooler
DATABASE_URL=postgresql://postgres.SEU_REF:SUA_SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres

# Exemplo real (troque SENHA pela senha do seu projeto):
# DATABASE_URL=postgresql://postgres.aiugalructdnxrcrqnhj:SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres
